# Basic gitignore
/[Tt]emp/
*.exe

# Claude Code settings
.claude/settings.local.json

# Secrets — never commit API keys (.env.example stays tracked)
.env
*.env

video-generation/*

# Local media + project workspaces (not tracked)
media-generation/*
!media-generation/STORYBOARD-PROMPT-KIT.md
projects/

# macOS
.DS_Store